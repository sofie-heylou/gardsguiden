# Build output — rebuilt inside Docker
.next/
node_modules/

# Scrapers — local-only tools, never deployed.
# Exception: baseline-meta.ts is a one-shot prod migration helper (Stage 1.2).
scripts/*
!scripts/baseline-meta.ts

# Scraper intermediate files
data/tmp/

# Secrets — never bake into the image
.env.local
.env*.local

# Git
.git/
.gitignore

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Docker files themselves
Dockerfile
.dockerignore

# Logs
*.log
npm-debug.log*

# Test / analysis artifacts
.next/analyze/
coverage/
